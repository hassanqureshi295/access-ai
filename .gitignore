# AccessAI .gitignore

# --- Environment & secrets ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
backend/.venv/
venv/
.venv/
env/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
.eggs/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Runtime JSON data (users, chat history)
backend/data/

# --- Node / Frontend ---
frontend/node_modules/
node_modules/
frontend/dist/
dist/
.npm
*.tsbuildinfo

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS & editor ---
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# --- Vite ---
*.local
