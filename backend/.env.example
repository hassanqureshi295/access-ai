# AccessAI Backend Environment Variables
# Copy this file to .env and fill in your values before running the server.

# Google Gemini API key (required for AI chat responses)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use for chat completions
GEMINI_MODEL=gemini-2.0-flash

# Server host and port
HOST=0.0.0.0
PORT=8000

# Allowed CORS origins (comma-separated; frontend dev server URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT secret for authentication tokens (use a long random string in production)
JWT_SECRET=change-this-to-a-secure-random-secret-in-production

# JWT token expiration in minutes
JWT_EXPIRE_MINUTES=1440

# Application environment: development | production
APP_ENV=development

# Enable debug logging when true
DEBUG=true
